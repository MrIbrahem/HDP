# Wikimedia Commons Bot Credentials
# Copy this file to .env and fill in your credentials
# DO NOT commit the .env file to version control

# Your Wikimedia Commons bot username
WIKIPEDIA_BOT_USERNAME=YourBotUsername

# Your bot password (generated from Special:BotPasswords)
WIKIPEDIA_BOT_PASSWORD=YourSecurePassword

# Optional - defaults to current directory if not set
MAIN_DIR=/path/to/your/project/root
